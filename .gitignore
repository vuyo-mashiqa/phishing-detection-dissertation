# ============================================================
# PHISHING DETECTION DISSERTATION — .gitignore
# ============================================================

# Raw corpus data — never commit (large files, PII, licence constraints)
data/raw/

# Python virtual environment — never commit
.venv/
venv/
env/

# Python bytecode
__pycache__/
*.py[cod]
*$py.class
*.pyc

# Environment variable files (API keys, credentials)
.env
.env.*
secrets.ini

# Large model checkpoints and weights
*.bin
*.safetensors
*.pt
*.ckpt
results/checkpoints/

# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# OS-generated files
.DS_Store
Thumbs.db
desktop.ini

# Editor files
.vscode/settings.json
*.swp
*.swo

# Temporary files
*.tmp
*.temp
~$*

# IDE configuration files
.idea/
*.iml

# Processed data CSVs — too large for GitHub (>100 MB).
# Regenerated by running the parsers from raw data.
# Raw data is also excluded (data/raw/ already in .gitignore).
data/processed/

# Split CSVs — regenerated by generate_splits.py
data/splits/

# Reproducible ML artefacts - excluded from version control
outputs/features/**/*.npz
outputs/features/**/*.npy
outputs/features/**/*.joblib
outputs/transformers/**/*.pt
outputs/transformers/**/*.bin
data/processed/token_cache/
models/

# Old diagnostic/one-off scripts
src/data/diagnose_*.py
src/data/extract_structural_features.py
