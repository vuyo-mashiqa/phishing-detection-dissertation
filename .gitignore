# ============================================================
# PHISHING DETECTION DISSERTATION — .gitignore
# ============================================================

# Raw corpus data — never commit (large files, PII, licence constraints)
data/raw/

# Python virtual environment — never commit
.venv/
venv/
env/

# Python bytecode
__pycache__/
*.py[cod]
*$py.class
*.pyc

# Environment variable files (API keys, credentials)
.env
.env.*
secrets.ini

# Large model checkpoints and weights
*.bin
*.safetensors
*.pt
*.ckpt
results/checkpoints/

# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# OS-generated files
.DS_Store
Thumbs.db
desktop.ini

# Editor files
.vscode/settings.json
*.swp
*.swo

# Temporary files
*.tmp
*.temp
~$*
